#!/usr/bin/env bash
# git post-commit hook: when a commit touches core/ir/prompts/*.yaml (a prompt
# version bump), auto-run the golden eval for every attribute that already has
# human labels, and print the ledger diff vs the previous version.
#
# Install (from the repo that tracks core/ir):
#   ln -sf ../../core/ir/eval/hooks/post-commit-prompt-eval \
#      "$(git rev-parse --git-path hooks/post-commit)"
#
# It never blocks the commit — it only measures and reports. Scoring here uses
# the DB snapshot (current deployed version). To score an UNDEPLOYED new prompt
# on the golden crops without a full reindex, run re_score.py first (GPU).

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo .)"
EVAL_DIR="$REPO_ROOT/core/ir/eval"
[ -d "$EVAL_DIR" ] || EVAL_DIR="$REPO_ROOT/eval"   # when hook runs inside core/ir
[ -d "$EVAL_DIR" ] || exit 0

# did this commit change any prompt yaml?
if ! git diff-tree --no-commit-id --name-only -r HEAD | grep -qE '(^|/)prompts/plr_.*\.ya?ml$'; then
  exit 0
fi

# resolve the live stamped version (what predictions in the DB are keyed by)
VER="$(cd "$REPO_ROOT" && python3 - <<'PY' 2>/dev/null || echo "")
try:
    import sys; sys.path.insert(0, "core/ir")
    from indexing import PROMPT_VERSION
    print(PROMPT_VERSION)
except Exception:
    pass
PY
)"
[ -n "$VER" ] || VER="plr_current"

echo "── [prompt-eval] prompt yaml changed → scoring golden sets (version=$VER) ──"
ran=0
for gdir in "$EVAL_DIR"/golden/*/; do
  attr="$(basename "$gdir")"
  if [ -f "$gdir/labels.jsonl" ] && [ -f "$gdir/predictions.jsonl" ]; then
    echo ""
    python3 "$EVAL_DIR/run_eval.py" --attribute "$attr" --version "$VER" || true
    ran=1
  fi
done
[ "$ran" = 0 ] && echo "  (no labeled golden set yet — label one, then this hook reports diffs)"
echo "── [prompt-eval] done — see $EVAL_DIR/ledger.jsonl ──"
