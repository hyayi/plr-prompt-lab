# plr-prompt-lab — example environment.
# Copy to `.env` and adjust, or `export` the vars you need. All are optional
# for the GPU-free mock/test path; the ones marked (real run) are only needed
# for `lab run` (GPU) and `lab port` / stale-seed checks against core/ir.

# --- core/ir location (for `lab port` and stale-seed checks) ---
# Path to a checkout of the upstream ir repo. No default is baked in; if unset
# the lab tries ../ziomilitary/core/ir next to this repo, then errors for
# commands that truly need it (port).
# CORE_IR_PATH=/path/to/ziomilitary/core/ir

# --- crop source for `lab build-golden` ---
# Root under which per-video object crops live: <RESULT_PATH>/<video>/objects/.
# Generic default is ./results (relative to CWD).
# RESULT_PATH=./results

# --- dataset selection (optional; --dataset flag overrides) ---
# A dataset dir = crops/<obj_id>.jpg + labels.jsonl + (optional) queries.jsonl
# + manifest.yaml. Left unset, commands fall back to eval/golden/<attribute>/.
# DATASET_DIR=./eval/golden/gender

# --- Gemma model (real run, GPU) ---
# GGUF repo + optional explicit main file. Default repo is the unsloth Q4_0 GGUF.
# IR_GEMMA_REPO=unsloth/gemma-4-E4B-it-GGUF
# IR_GEMMA_MAIN_FILE=gemma-4-E4B-it-Q4_0.gguf

# --- PLR prompt/reason format (real run) ---
# Version tags stamped into predictions/ledger; also selects prompt behavior.
# IR_PLR_FORMAT=plr_v1.4_cot
# IR_PLR_REASON=

# --- GPU selection (real run) ---
# Which CUDA device(s) `lab run` may use.
# CUDA_VISIBLE_DEVICES=0
